---
interface Props {
  title: string;
  href: string;
  category: string;
  image: string;
  excerpt?: string;
  publishedAt?: string;
  publishedLabel?: string;
  className?: string;
  linkEnabled?: boolean;
}

const {
  title,
  href,
  category,
  image,
  excerpt,
  publishedAt,
  publishedLabel,
  className = "",
  linkEnabled = true
} = Astro.props;
---
{linkEnabled ? (
  <a href={href} class={`article-card ${className}`}>
    <div class="article-card__image-wrap">
      <img src={image} alt={title} width="600" height="375" loading="lazy" />
    </div>
    <div class="article-card__body">
      <span class="article-card__category">{category}</span>
      <h3 class="article-card__title">{title}</h3>
      {excerpt && <p class="article-card__excerpt">{excerpt}</p>}
      {publishedAt && (
        <time class="article-card__time" datetime={publishedAt}>
          {publishedLabel ?? publishedAt}
        </time>
      )}
    </div>
  </a>
) : (
  <div class={`article-card ${className}`} style="pointer-events: none; cursor: default;">
    <div class="article-card__image-wrap">
      <img src={image} alt={title} width="600" height="375" loading="lazy" />
    </div>
    <div class="article-card__body">
      <span class="article-card__category">{category}</span>
      <h3 class="article-card__title">{title}</h3>
      {excerpt && <p class="article-card__excerpt">{excerpt}</p>}
      {publishedAt && (
        <time class="article-card__time" datetime={publishedAt}>
          {publishedLabel ?? publishedAt}
        </time>
      )}
    </div>
  </div>
)}
