---
interface Props {
  title: string;
  href: string;
  category: string;
  categorySlug?: string;
  image?: string;
  excerpt?: string;
  publishedAt?: string;
  publishedLabel?: string;
  className?: string;
  linkEnabled?: boolean;
}

const {
  title,
  href,
  category,
  categorySlug,
  image,
  excerpt,
  publishedAt,
  publishedLabel,
  className = "",
  linkEnabled = true
} = Astro.props;

const isKakera = category === "思考の欠片" || categorySlug === "kakera";
const showNoImage = isKakera && !image;
---
{linkEnabled ? (
  <a href={href} class={`article-card ${showNoImage ? "article-card--no-image" : ""} ${className}`}>
    {image && (
      <div class="article-card__image-wrap">
        <img src={image} alt={title} width="600" height="375" loading="lazy" />
      </div>
    )}
    <div class="article-card__body">
      <span class="article-card__category">{category}</span>
      <h3 class="article-card__title">{title}</h3>
      {excerpt && <p class="article-card__excerpt">{excerpt}</p>}
      {publishedAt && (
        <time class="article-card__time" datetime={publishedAt}>
          {publishedLabel ?? publishedAt}
        </time>
      )}
    </div>
  </a>
) : (
  <div class={`article-card ${showNoImage ? "article-card--no-image" : ""} ${className}`} style="pointer-events: none; cursor: default;">
    {image && (
      <div class="article-card__image-wrap">
        <img src={image} alt={title} width="600" height="375" loading="lazy" />
      </div>
    )}
    <div class="article-card__body">
      <span class="article-card__category">{category}</span>
      <h3 class="article-card__title">{title}</h3>
      {excerpt && <p class="article-card__excerpt">{excerpt}</p>}
      {publishedAt && (
        <time class="article-card__time" datetime={publishedAt}>
          {publishedLabel ?? publishedAt}
        </time>
      )}
    </div>
  </div>
)}
