---
import { categories } from '../data/categories';

interface Props {
  activeSection?: string;
  navigationEnabled?: boolean;
  searchEnabled?: boolean;
}

const { activeSection, navigationEnabled = true, searchEnabled = false } = Astro.props;

const orderedSlugs = [
  "satori",
  "hikiyose",
  "law",
  "mezame",
  "bunsho",
  "jissen",
  "tsushin",
  "kakera"
];

const orderedCategories = [...categories].sort((a, b) => {
  const indexA = orderedSlugs.indexOf(a.slug);
  const indexB = orderedSlugs.indexOf(b.slug);
  const posA = indexA !== -1 ? indexA : 999;
  const posB = indexB !== -1 ? indexB : 999;
  return posA - posB;
});
---
<header class="site-header" id="site-header">
  <div class="header-top-bar">
    {navigationEnabled ? (
      <a href="/" class="header-site-title">宇宙を悟り法則を引き寄せる</a>
    ) : (
      <span class="header-site-title" style="cursor: default;">宇宙を悟り法則を引き寄せる</span>
    )}
  </div>

  <nav class="header-nav-bar" aria-label="メインナビゲーション">
    <div class="header-nav-inner">
      <ul class="header-nav-list" id="nav-list">
        {orderedCategories.map((category) => (
          <li>
            {navigationEnabled ? (
              <a
                href={`/category/${category.slug}/`}
                class={activeSection === category.slug ? 'active' : ''}
                aria-current={activeSection === category.slug ? 'page' : undefined}
              >
                {category.name}
              </a>
            ) : (
              <a
                class={activeSection === category.slug ? 'active' : ''}
                aria-current={activeSection === category.slug ? 'page' : undefined}
                style="pointer-events: none; cursor: default; color: var(--color-text);"
                tabindex="-1"
              >
                {category.name}
              </a>
            )}
          </li>
        ))}
      </ul>

      {searchEnabled ? (
        <button class="header-search-btn" aria-label="検索">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="7"/>
            <line x1="16.5" y1="16.5" x2="21" y2="21"/>
          </svg>
        </button>
      ) : (
        <button
          type="button"
          class="header-search-btn"
          disabled
          aria-disabled="true"
          aria-label="検索（準備中）"
          style="opacity: 0.4; cursor: not-allowed;"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="7"/>
            <line x1="16.5" y1="16.5" x2="21" y2="21"/>
          </svg>
        </button>
      )}
    </div>
  </nav>
</header>
