---
import { getCollection } from 'astro:content';
import { categories } from '../../data/categories';
import CategoryLayout from '../../layouts/CategoryLayout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');

  return categories.map((category) => {
    const sortedArticles = articles
      .filter((article) => article.data.categorySlug === category.slug)
      .sort((a, b) => {
        const dateComparison = b.data.publishedAt.localeCompare(a.data.publishedAt);
        if (dateComparison !== 0) return dateComparison;
        return a.data.slug.localeCompare(b.data.slug);
      });

    return {
      params: { slug: category.slug },
      props: {
        categorySlug: category.slug,
        categoryName: category.name,
        categoryEnglishName: category.englishName,
        categoryDescription: category.description,
        theme: category.theme,
        articles: sortedArticles,
      },
    };
  });
}

const {
  categorySlug,
  categoryName,
  categoryEnglishName,
  categoryDescription,
  theme,
  articles,
} = Astro.props;
---
<CategoryLayout
  categorySlug={categorySlug}
  categoryName={categoryName}
  categoryEnglishName={categoryEnglishName}
  categoryDescription={categoryDescription}
  theme={theme}
  articles={articles}
/>
