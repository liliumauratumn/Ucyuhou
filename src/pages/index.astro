---
// index.astro - Official Top Page
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import '../styles/pages/top.css';

const allArticles = await getCollection('articles');

// Map articles by slug for quick lookup
const articlesBySlug = new Map(allArticles.map(a => [a.data.slug, a]));

const getArticle = (slug: string) => {
  const art = articlesBySlug.get(slug);
  if (!art) {
    throw new Error(`Article with slug "${slug}" not found in Content Collections.`);
  }
  return art;
};

// Main Story
const mainStory = getArticle('satori');
const sidebar1 = getArticle('bunsho');
const sidebar2 = getArticle('maharshi');
const sidebar3 = getArticle('law');
const sidebar4 = getArticle('quantum');
const sub1 = getArticle('hikiyose');
const sub2 = getArticle('emerald');

// Latest Articles
const latestArticles = [...allArticles]
  .sort((a, b) => {
    const dateComparison = b.data.publishedAt.localeCompare(a.data.publishedAt);
    if (dateComparison !== 0) return dateComparison;
    return a.data.slug.localeCompare(b.data.slug);
  });

const latest1 = latestArticles[0];
const latest2 = latestArticles[1];
const latest3 = latestArticles[2];
const latest4 = latestArticles[3];
const latest5 = latestArticles[4];
const latest6 = latestArticles[5];
const latest7 = latestArticles[6];
const latest8 = latestArticles[7];

// Recommended
const rec1 = getArticle('tolle');
const rec2 = getArticle('hikiyose');
const rec3 = getArticle('mirror');
const rec4 = getArticle('emerald-prep');

// Feature
const feat1 = getArticle('discard');
const feat2 = getArticle('no-resistance');
const feat3 = getArticle('vortex');
---
<BaseLayout title="宇宙を悟り法則を引き寄せる | うちゅ法" description="悟り、引き寄せ、宇宙法則、覚者の教えを静かに読み解く思想メディア。">
  <SiteHeader navigationEnabled={true} searchEnabled={true} />

  <main>
    <h1 class="visually-hidden">宇宙を悟り法則を引き寄せる</h1>
    
    <!-- ═══════════════════════════════════════════════
         LOGO HERO
         ═══════════════════════════════════════════════ -->
    <section class="section logo-hero" id="logo-hero">
      <div class="site-container text-center">
        <img
          class="logo-hero__image"
          src="/assets/images/Ucyuhou_bk.png"
          alt="うちゅ法"
          width="800"
          height="800"
        />
        <p class="logo-hero__subtitle">悟り、引き寄せ、宇宙法則を静かに読み解く</p>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         MAIN STORY
         ═══════════════════════════════════════════════ -->
    <section class="section main-story" id="main-story">
      <div class="site-container">
        <div class="main-story__grid">
          <!-- Left: Text -->
          <article class="main-story__text">
            <span class="article-card__category">{mainStory.data.category}</span>
            <h2 class="main-story__title">
              <a href={`/articles/${mainStory.data.slug}/`}>{mainStory.data.title}</a>
            </h2>
            <p class="main-story__excerpt">
              {mainStory.data.description}
            </p>
            <time class="article-card__time" datetime={mainStory.data.publishedAt}>
              {mainStory.data.publishedLabel}
            </time>
          </article>

          <!-- Center: Image -->
          <div class="main-story__image">
            <a href={`/articles/${mainStory.data.slug}/`}>
              <img src={mainStory.data.heroImage} alt={mainStory.data.heroAlt} width="800" height="500" loading="eager" />
            </a>
          </div>

          <!-- Right: Headline sidebar (Reuters pattern) -->
          <aside class="main-story__sidebar" aria-label="関連記事">
            <ul class="main-story__sidebar-list">
              <li class="main-story__sidebar-item">
                <a href={`/articles/${sidebar1.data.slug}/`}>
                  <h3 class="main-story__sidebar-title">{sidebar1.data.title}</h3>
                  <time class="article-card__time" datetime={sidebar1.data.publishedAt}>{sidebar1.data.publishedLabel}</time>
                </a>
              </li>
              <li class="main-story__sidebar-item">
                <a href={`/articles/${sidebar2.data.slug}/`}>
                  <h3 class="main-story__sidebar-title">{sidebar2.data.title}</h3>
                  <time class="article-card__time" datetime={sidebar2.data.publishedAt}>{sidebar2.data.publishedLabel}</time>
                </a>
              </li>
              <li class="main-story__sidebar-item">
                <a href={`/articles/${sidebar3.data.slug}/`}>
                  <h3 class="main-story__sidebar-title">{sidebar3.data.title}</h3>
                  <time class="article-card__time" datetime={sidebar3.data.publishedAt}>{sidebar3.data.publishedLabel}</time>
                </a>
              </li>
              <li class="main-story__sidebar-item">
                <a href={`/articles/${sidebar4.data.slug}/`}>
                  <h3 class="main-story__sidebar-title">{sidebar4.data.title}</h3>
                  <time class="article-card__time" datetime={sidebar4.data.publishedAt}>{sidebar4.data.publishedLabel}</time>
                </a>
              </li>
            </ul>
          </aside>
        </div>

        <!-- Sub stories -->
        <div class="main-story__sub">
          <article class="article-card">
            <a href={`/articles/${sub1.data.slug}/`}>
              <div class="article-card__image-wrap">
                <img src={sub1.data.heroImage} alt={sub1.data.heroAlt} width="600" height="375" loading="lazy" />
              </div>
              <span class="article-card__category">{sub1.data.category}</span>
              <h3 class="article-card__title">{sub1.data.title}</h3>
              <time class="article-card__time" datetime={sub1.data.publishedAt}>{sub1.data.publishedLabel}</time>
            </a>
          </article>
          <article class="article-card">
            <a href={`/articles/${sub2.data.slug}/`}>
              <div class="article-card__image-wrap">
                <img src={sub2.data.heroImage} alt={sub2.data.heroAlt} width="600" height="375" loading="lazy" />
              </div>
              <span class="article-card__category">{sub2.data.category}</span>
              <h3 class="article-card__title">{sub2.data.title}</h3>
              <time class="article-card__time" datetime={sub2.data.publishedAt}>{sub2.data.publishedLabel}</time>
            </a>
          </article>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         LATEST ARTICLES
         ═══════════════════════════════════════════════ -->
    <section class="section latest-articles" id="latest-articles">
      <div class="site-container">
        <h2 class="section-title"><a href="#latest-articles">最新記事 &rsaquo;</a></h2>
        <div class="latest-articles__grid">
          <article class="latest-articles__item">
            <a href={`/articles/${latest1.data.slug}/`}>
              <h3 class="latest-articles__title">{latest1.data.title}</h3>
              <time class="article-card__time" datetime={latest1.data.publishedAt}>{latest1.data.publishedLabel}</time>
            </a>
          </article>
          <article class="latest-articles__item">
            <a href={`/articles/${latest2.data.slug}/`}>
              <h3 class="latest-articles__title">{latest2.data.title}</h3>
              <time class="article-card__time" datetime={latest2.data.publishedAt}>{latest2.data.publishedLabel}</time>
            </a>
          </article>
          <article class="latest-articles__item">
            <a href={`/articles/${latest3.data.slug}/`}>
              <h3 class="latest-articles__title">{latest3.data.title}</h3>
              <time class="article-card__time" datetime={latest3.data.publishedAt}>{latest3.data.publishedLabel}</time>
            </a>
          </article>
          <article class="latest-articles__item">
            <a href={`/articles/${latest4.data.slug}/`}>
              <h3 class="latest-articles__title">{latest4.data.title}</h3>
              <time class="article-card__time" datetime={latest4.data.publishedAt}>{latest4.data.publishedLabel}</time>
            </a>
          </article>
          <article class="latest-articles__item">
            <a href={`/articles/${latest5.data.slug}/`}>
              <h3 class="latest-articles__title">{latest5.data.title}</h3>
              <time class="article-card__time" datetime={latest5.data.publishedAt}>{latest5.data.publishedLabel}</time>
            </a>
          </article>
          <article class="latest-articles__item">
            <a href={`/articles/${latest6.data.slug}/`}>
              <h3 class="latest-articles__title">{latest6.data.title}</h3>
              <time class="article-card__time" datetime={latest6.data.publishedAt}>{latest6.data.publishedLabel}</time>
            </a>
          </article>
          <article class="latest-articles__item">
            <a href={`/articles/${latest7.data.slug}/`}>
              <h3 class="latest-articles__title">{latest7.data.title}</h3>
              <time class="article-card__time" datetime={latest7.data.publishedAt}>{latest7.data.publishedLabel}</time>
            </a>
          </article>
          <article class="latest-articles__item">
            <a href={`/articles/${latest8.data.slug}/`}>
              <h3 class="latest-articles__title">{latest8.data.title}</h3>
              <time class="article-card__time" datetime={latest8.data.publishedAt}>{latest8.data.publishedLabel}</time>
            </a>
          </article>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         RECOMMENDED
         ═══════════════════════════════════════════════ -->
    <section class="section recommended" id="recommended">
      <div class="site-container">
        <h2 class="section-title">宇宙からのおすすめ</h2>
        <div class="recommended__grid">
          <ArticleCard
            title={rec1.data.title}
            href={`/articles/${rec1.data.slug}/`}
            category={rec1.data.category}
            image={rec1.data.heroImage}
            publishedAt={rec1.data.publishedAt}
            publishedLabel={rec1.data.publishedLabel}
          />
          <ArticleCard
            title={rec2.data.title}
            href={`/articles/${rec2.data.slug}/`}
            category={rec2.data.category}
            image={rec2.data.heroImage}
            publishedAt={rec2.data.publishedAt}
            publishedLabel={rec2.data.publishedLabel}
          />
          <ArticleCard
            title={rec3.data.title}
            href={`/articles/${rec3.data.slug}/`}
            category={rec3.data.category}
            image={rec3.data.heroImage}
            publishedAt={rec3.data.publishedAt}
            publishedLabel={rec3.data.publishedLabel}
          />
          <ArticleCard
            title={rec4.data.title}
            href={`/articles/${rec4.data.slug}/`}
            category={rec4.data.category}
            image={rec4.data.heroImage}
            publishedAt={rec4.data.publishedAt}
            publishedLabel={rec4.data.publishedLabel}
          />
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         FEATURE
         ═══════════════════════════════════════════════ -->
    <section class="section feature" id="feature">
      <div class="site-container">
        <h2 class="section-title">特集: 引き寄せを欲望から解放する</h2>
        <div class="feature__grid">
          <ArticleCard
            title={feat1.data.title}
            href={`/articles/${feat1.data.slug}/`}
            category={feat1.data.category}
            image={feat1.data.heroImage}
            excerpt={feat1.data.description}
            publishedAt={feat1.data.publishedAt}
            publishedLabel={feat1.data.publishedLabel}
          />
          <ArticleCard
            title={feat2.data.title}
            href={`/articles/${feat2.data.slug}/`}
            category={feat2.data.category}
            image={feat2.data.heroImage}
            excerpt={feat2.data.description}
            publishedAt={feat2.data.publishedAt}
            publishedLabel={feat2.data.publishedLabel}
          />
          <ArticleCard
            title={feat3.data.title}
            href={`/articles/${feat3.data.slug}/`}
            category={feat3.data.category}
            image={feat3.data.heroImage}
            excerpt={feat3.data.description}
            publishedAt={feat3.data.publishedAt}
            publishedLabel={feat3.data.publishedLabel}
          />
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         NEWSLETTER
         ═══════════════════════════════════════════════ -->
    <section class="section newsletter" id="newsletter">
      <div class="site-container text-center">
        <h2 class="newsletter__title">宇宙通信</h2>
        <p class="newsletter__status" style="color:#d9534f; font-size:var(--fs-xs); margin-top:var(--sp-xs); font-weight:bold;">※現在準備中です</p>
        <p class="newsletter__subtitle">
          悟り、引き寄せ、意識、宇宙法則についての短い便り。<br />
          記事になる前の断章が、宇宙から届きます。
        </p>
        <div class="newsletter__form">
          <div class="newsletter__input-group">
            <input
              type="email"
              class="input newsletter__input"
              placeholder="メールアドレス"
              aria-label="メールアドレス"
              disabled
            />
            <button type="button" class="btn newsletter__btn" disabled style="opacity: 0.6; cursor: not-allowed;">
              準備中
            </button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter categoryLinksEnabled={true} staticLinksEnabled={true} />
</BaseLayout>
