---
import BaseLayout from './BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ArticleCard from '../components/ArticleCard.astro';
import '../styles/pages/article.css';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  subtitle?: string;
  description: string;
  category: string;
  categorySlug: string;
  tags?: string[];
  authorName?: string;
  readTime?: string;
  publishedAt: string;
  publishedLabel: string;
  heroImage?: string;
  heroAlt?: string;
  theme: 'default' | 'cosmic';
  slug: string;
}

const {
  title,
  subtitle,
  description,
  category,
  categorySlug,
  tags = [],
  authorName,
  readTime,
  publishedAt,
  publishedLabel,
  heroImage,
  heroAlt,
  theme,
  slug,
} = Astro.props;

// Fetch related articles (same category, excluding current)
const allArticles = await getCollection('articles');
const relatedArticles = allArticles
  .filter(item => item.data.categorySlug === categorySlug && item.data.slug !== slug)
  .slice(0, 3);

const bodyClass = theme === 'cosmic' ? 'theme-inverted' : undefined;

// JSON-LD 用の絶対URL生成
const siteUrl = Astro.site || 'https://ucyuhou.vercel.app';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const absoluteHeroImage = heroImage ? new URL(heroImage, siteUrl).href : undefined;

// Article JSON-LD
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": publishedAt,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL.href
  },
  "articleSection": category,
  "author": {
    "@type": "Organization",
    "name": "宇宙を悟り法則を引き寄せる",
    "url": "https://ucyuhou.vercel.app/"
  },
  ...(absoluteHeroImage ? { "image": [absoluteHeroImage] } : {})
};

// BreadcrumbList JSON-LD
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "ホーム",
      "item": "https://ucyuhou.vercel.app/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": category,
      "item": new URL(`/category/${categorySlug}/`, siteUrl).href
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": title,
      "item": canonicalURL.href
    }
  ]
};
---
<BaseLayout
  title={`${title} | 宇宙を悟り法則を引き寄せる`}
  description={description}
  bodyClass={bodyClass}
  heroImage={heroImage}
  heroAlt={heroAlt}
  ogType="article"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
  <SiteHeader activeSection={categorySlug} navigationEnabled={true} searchEnabled={true} />

  <main>
    <article>
      <!-- Article Header -->
      <header class="article-header article-container">
        <div class="article-meta-info">
          <a href={`/category/${categorySlug}/`} class="article-category-link">{category} ↗</a>
          {tags.length > 1 && (
            <span class="article-meta-tags">
              {tags.slice(1).map((tag, index) => (
                <span class="article-plain-tag">
                  {tag}{index < tags.length - 2 && <span class="article-tag-separator">・</span>}
                </span>
              ))}
            </span>
          )}
        </div>

        <h1 class="article-title">{title}</h1>

        {subtitle && <p class="article-subtitle">{subtitle}</p>}

        <div class="article-author">
          <img class="article-author__avatar" src="/assets/images/Ucyuhou_bk_70px.png" alt="宇宙を悟り法則を引き寄せる" />
          <div class="article-author__info">
            <span class="article-author__name">{authorName || "宇宙を悟り法則を引き寄せる"}</span>
            <span class="article-author__meta">
              {readTime ? `${readTime} · ` : ''}{publishedLabel}
            </span>
          </div>
        </div>
      </header>

      <!-- Hero Image -->
      {heroImage && (
        <div class="article-hero">
          <img src={heroImage} alt={heroAlt || title} width="1200" height="600" loading="eager">
        </div>
      )}

      <!-- Article Content -->
      <div class="article-body article-container">
        <slot />
      </div>

      <!-- Article Footer -->
      {tags.length > 1 && (
        <footer class="article-footer article-container">
          <div class="article-meta-info">
            <span class="article-meta-tags">
              {tags.slice(1).map((tag, index) => (
                <span class="article-plain-tag">
                  {tag}{index < tags.length - 2 && <span class="article-tag-separator">・</span>}
                </span>
              ))}
            </span>
          </div>
        </footer>
      )}
    </article>

    <!-- Related Articles -->
    {relatedArticles.length > 0 && (
      <section class="related-section">
        <div class="site-container">
          <h3 class="related-section__title">関連記事</h3>
          <div class="related-grid">
            {relatedArticles.map(item => (
              <ArticleCard
                title={item.data.title}
                href={`/articles/${item.data.slug}/`}
                category={item.data.category}
                image={item.data.heroImage}
                excerpt={item.data.description}
                publishedAt={item.data.publishedAt}
                publishedLabel={item.data.publishedLabel}
              />
            ))}
          </div>
        </div>
      </section>
    )}
  </main>

  <SiteFooter categoryLinksEnabled={true} staticLinksEnabled={true} />
</BaseLayout>
